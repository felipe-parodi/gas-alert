# Copy to .env for local runs (export these), or set as GitHub Actions secrets.

# Your cities, as a JSON list. Kept in a secret so a public repo doesn't
# reveal where you live/drive. Unset = demo cities (SF/Oakland/Berkeley).
CITIES_JSON='[{"name":"San Francisco","short":"SF","search":"San Francisco, CA","lat":37.7749,"lng":-122.4194},{"name":"Oakland","short":"Oak","search":"Oakland, CA","lat":37.8044,"lng":-122.2712}]'

# Gmail account that sends the alert. Use an app password:
# Google Account -> Security -> 2-Step Verification -> App passwords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where the email goes (defaults to GMAIL_ADDRESS if unset)
EMAIL_TO=

# Free SMS via T-Mobile's email-to-SMS gateway. Leave unset to skip SMS.
SMS_TO=4085551234@tmomail.net

# Optional: ntfy.sh push topic (more reliable than carrier SMS gateways).
# Pick a long random topic name and subscribe in the ntfy app.
NTFY_TOPIC=

# Stations to skip (membership-only pumps). Comma-separated, case-insensitive
# substring match on station name. Unset = costco, bj's, sam's club.
# (In GitHub Actions this is a repo *variable*, not a secret.)
EXCLUDE_STATIONS=

# Which maps app the SMS link opens: apple | google | waze (email always
# includes all three). Repo variable in Actions. Default: apple.
MAPS_APP=

# Fallback data source: Google Places API (New). Enable "Places API (New)"
# in a Google Cloud project and create an API key. ~90 requests/month is
# well inside the free tier.
GOOGLE_MAPS_API_KEY=
